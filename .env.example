# 可选路径覆盖；相对路径以进程工作目录为基准解析。
TRAVELMIND_ASSETS_DIR=assets
TRAVELMIND_TRAVEL_CSV=assets/travel_guide.csv
TRAVELMIND_FAISS_INDEX_DIR=assets/faiss_index
TRAVELMIND_MULTIMODAL_MARKDOWN_DIR=assets/result_markdown
TRAVELMIND_GRAPHRAG_CONFIG_DIR=assets/graphrag_runtime
TRAVELMIND_GRAPHRAG_OUTPUT_DIR=assets/graphrag_output

# 默认运行配置具备可复现性，且资源开销较低。
TRAVELMIND_RUNTIME_PROFILE=
TRAVELMIND_LLM_ENABLED=false
TRAVELMIND_SYSTEM_AGENT_LLM_ROUTER_ENABLED=false
TRAVELMIND_LLM_GRADE_ENABLED=false
TRAVELMIND_LLM_REWRITE_ENABLED=false
TRAVELMIND_LLM_GENERATE_ENABLED=false
TRAVELMIND_NAIVE_AGENT_LLM_LOOP_ENABLED=false

# 标准 TravelMind 大模型与嵌入向量配置。
TRAVELMIND_LLM_API_KEY=
TRAVELMIND_LLM_BASE_URL=https://api.deepseek.com
TRAVELMIND_LLM_MODEL=deepseek-chat
TRAVELMIND_EMBEDDING_API_KEY=
TRAVELMIND_EMBEDDING_MODEL=text-embedding-v3

# 当独立凭据、本地 Parquet 与 LanceDB 资产就绪后，
# Official GraphRAG Local Search 将作为 GraphRAG 默认正式链路。
TRAVELMIND_GRAPHRAG_LLM_API_KEY=
TRAVELMIND_GRAPHRAG_LLM_BASE_URL=
TRAVELMIND_GRAPHRAG_LLM_CHAT_MODEL=
TRAVELMIND_GRAPHRAG_LLM_EMBEDDING_MODEL=
TRAVELMIND_GRAPHRAG_TIMEOUT_SECONDS=180
TRAVELMIND_GRAPHRAG_MAX_CONTEXT_CHARS=6000

# Global Search 需同时开启服务级开关与请求级 UI/API 开关。
TRAVELMIND_GRAPHRAG_GLOBAL_SEARCH_ENABLED=false
# Hybrid 单分支超时预算。
TRAVELMIND_HYBRID_BRANCH_TIMEOUT_SECONDS=20

# 完整请求与回答日志可能包含用户数据，默认关闭。
TRAVELMIND_RUN_LOG_ENABLED=false
